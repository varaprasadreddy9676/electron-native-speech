{
  "name": "electron-native-speech",
  "version": "0.1.6",
  "description": "Native OS speech transcription for Electron apps — fast, local, no cloud required",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./preload": {
      "require": "./dist/preload.js",
      "types": "./dist/preload.d.ts"
    },
    "./main-handlers": {
      "require": "./dist/main-handlers.js",
      "types": "./dist/main-handlers.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "preload": [
        "dist/preload.d.ts"
      ],
      "main-handlers": [
        "dist/main-handlers.d.ts"
      ]
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "electron",
    "speech",
    "transcription",
    "macos",
    "native",
    "speech-recognition",
    "offline",
    "local"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "electron": ">=28.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "dependencies": {
    "electron-native-speech-backend-macos": "^0.1.7",
    "electron-native-speech-preload": "^0.1.4"
  }
}
